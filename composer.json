{
    "name": "topvendor/vspay",
    "description": "Laravel SDK for the VSPay merchant API (payments, refunds, gateway operations, checkout, webhooks).",
    "keywords": ["vspay", "laravel", "payments", "sdk", "merchant", "api"],
    "homepage": "https://github.com/topvendor/vspay",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "TopVendor",
            "homepage": "https://github.com/topvendor"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.5",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/http": "^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "laravel/pint": "^1.13",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Topvendor\\Vspay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Topvendor\\Vspay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "pint": "pint",
        "pint:test": "pint --test",
        "stan": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Topvendor\\Vspay\\VspayServiceProvider"
            ],
            "aliases": {
                "Vspay": "Topvendor\\Vspay\\Facades\\Vspay"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
